# ============================================
# NEON DATABASE CONFIGURATION
# ============================================
# Dapatkan DATABASE_URL dari Neon Console:
# 1. Login ke https://console.neon.tech
# 2. Pilih project Anda
# 3. Klik "Connection Details"
# 4. Copy "Connection string" (format: postgresql://user:pass@host/db)

DATABASE_URL=postgresql://username:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: Neon API Key (untuk management via API)
NEON_API_KEY=nkey_xxxxxxxxxxxxxxxxxxxxx
